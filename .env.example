# Postgres / Prisma (recommended: Neon)
# Use the direct connection string from Neon for migrations + runtime.
# Example:
# DATABASE_URL=postgresql://user:password@ep-xxxxxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:password@your-neon-host/neondb?sslmode=require

# Notion CMS — https://www.notion.so/my-integrations
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxx
# The ID of your Notion database (32-char hex from the URL)
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Resend (newsletter emails) — https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx
# Segment ID (preferred) or legacy Audience ID. How to get it:
# 1. Dashboard: Resend → Audience → Segments → create or open a segment → ID is in the URL or segment settings.
# 2. API: POST https://api.resend.com/segments with {"name": "Newsletter"} → use the "id" from the response.
RESEND_SEGMENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Legacy (deprecated); use RESEND_SEGMENT_ID if possible.
RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Google reCAPTCHA v3 (spam protection on forms) — https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_site_key_here
RECAPTCHA_SECRET_KEY=your_secret_key_here

# Site URL (used for sitemap, OG images, canonical URLs)
NEXT_PUBLIC_SITE_URL=https://thepuneetstory.com

# Google Tag Manager — https://tagmanager.google.com
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
